{
	"name": "strip-undefined",
	"version": "1.0.0",
	"description": "Remove undefined properties from objects, making exactOptionalPropertyTypes easier",
	"license": "MIT",
	"author": {
		"name": "thea"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/theacrat/strip-undefined"
	},
	"files": [
		"dist"
	],
	"type": "module",
	"sideEffects": false,
	"main": "./dist/index.cjs",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.cts",
	"exports": {
		".": {
			"require": "./dist/index.cjs",
			"import": "./dist/index.mjs"
		},
		"./package.json": "./package.json"
	},
	"scripts": {
		"build": "tsdown",
		"format": "oxfmt",
		"lint": "oxlint --type-aware --type-check --fix --fix-suggestions",
		"prepare": "husky",
		"release": "bun run build && bun publish"
	},
	"devDependencies": {
		"@tsconfig/recommended": "^1.0.13",
		"@tsconfig/strictest": "^2.0.8",
		"@types/node": "^25.0.8",
		"husky": "^9.1.7",
		"jiti": "^2.6.1",
		"lint-staged": "^16.2.7",
		"oxfmt": "^0.34.0",
		"oxlint": "^1.49.0",
		"oxlint-tsgolint": "^0.14.2",
		"tsdown": "^0.18.1",
		"typescript": "^5.9.3"
	},
	"lint-staged": {
		"*": [
			"bun lint",
			"bun format"
		]
	}
}
